Sub RGB格式化(s As String, outrgb() As Integer)
   Dim parts() As String
   Dim i       As Integer, index As Integer
   Dim cleaned As String
   
   ' 1. 将所有逗号替换为空格，统一分隔符
   cleaned = YF_Replace(s, ",", " ")
   
   ' 2. 按空格分割成数组（连续空格会产生空字符串）
   vbSplit(cleaned, " ", parts())
   
   ' 3. 遍历 parts，提取有效数字存入 rgb 数组
   index = 0
   For i = 0 To UBound(parts)
      cleaned = Trim(parts(i))
      If Len(cleaned) > 0 Then
         outrgb(index) = Val(cleaned)
         index += 1
         If index >= 3 Then Exit For 
      End If
   Next i
End Sub

Sub HEXToRGB(s As String, outrgb() As Integer)
   Dim localHex As String
   Dim r        As Byte, g As Byte, b As Byte
   
   ' 去除前导的 "#" 号（如果有）
   localHex = Trim(s)
   If Left(localHex, 1) = "#" Then
      localHex = Mid(localHex, 2)
   End If
   
   ' 提取红、绿、蓝分量（至少需要6个字符）
   If Len(localHex) >= 6 Then
      outrgb(0) = Val("&h" + Mid(localHex, 1, 2))
      outrgb(1) = Val("&h" + Mid(localHex, 3, 2))
      outrgb(2) = Val("&h" + Mid(localHex, 5, 2))
   End If

End Sub

'[Form1.Command4]事件 : 单击
'hWndForm    当前窗口的句柄(WIN系统用来识别窗口的一个编号，如果多开本窗口，必须 Me.hWndForm = hWndForm 后才可以执行后续操作本窗口的代码)
'hWndControl 当前控件的句柄(也是窗口句柄，如果多开本窗口，必须 Me.控件名.hWndForm = hWndForm 后才可以执行后续操作本控件的代码 )
Sub Form1_Command4_BN_Clicked(hWndForm As hWnd, hWndControl As hWnd)
   Dim s As String
   Dim parts() As String
   Dim count As Long
   Dim i As Integer

   ' 获取剪贴板文本
   s = FF_ClipboardGetText()
   If s = "" Then Exit Sub   ' 剪贴板为空则退出

   ' 按空格分割字符串，返回分割后的数组元素个数
   count = vbSplit(s, " ", parts())

   ' 确保至少有2个颜色代码（背和正）
   If count >= 1 Then
      Hex背.Text = parts(0)
   End If
   If count >= 2 Then
      Hex正.Text = parts(1)
   End If

   ' 从第三个颜色代码开始，依次赋值给 Hex标 控件数组
   ' 假设 Hex标 数组索引从0开始，例如 Hex标(0).Text, Hex标(1).Text ...
   ' 如果实际控件数量不足，可根据需要调整循环上限（例如使用 Hex标_Count 或固定数量）
   For i = 2 To count - 1
      ' 这里假设 Hex标 数组有足够多的元素，若不确定可添加数量检查
      Hex标(i - 2).Text = parts(i)
   Next i

End Sub




