DimP 正在更新 As Boolean = False
'[Form1.Hex背]事件 : HEX变动了，同步到RGB
Sub Form1_Hex背_EN_Change(hWndForm As hWnd, hWndControl As hWnd)
   Dim n(2) As Integer
   If 正在更新 Then Exit Sub ' 检查锁
   正在更新 = True ' 如果没锁，那么先上锁，再修改
   HEXToRGB(Hex背.Text, n())
   RGB背.Text = Str(n(0)) & "," & Str(n(1)) & "," & Str(n(2))
   正在更新   = False ' 改完了，开锁
End Sub

'[Form1.RGB背]事件 : RGB变动了，同步到HEX
Sub Form1_RGB背_EN_Change(hWndForm As hWnd, hWndControl As hWnd)
   Dim n(2) As Integer
   Dim s As String
   If 正在更新 Then Exit Sub ' 检查锁
   正在更新 = True ' 如果没锁，那么先上锁，再修改
   RGB格式化(RGB背.Text, n())
   s =Right("0" & Hex(n(0)), 2) + Right("0" & Hex(n(1)), 2) + Right("0" & Hex(n(2)), 2)
   Hex背.Text =  s
   正在更新   = False ' 改完了，开锁
End Sub

'[Form1.Hex正]事件 : HEX变动了，同步到RGB
Sub Form1_Hex正_EN_Change(hWndForm As hWnd, hWndControl As hWnd)
   Dim n(2) As Integer
   If 正在更新 Then Exit Sub ' 检查锁
   正在更新 = True ' 如果没锁，那么先上锁，再修改
   HEXToRGB(Hex正.Text, n())
   RGB正.Text = Str(n(0)) & "," & Str(n(1)) & "," & Str(n(2))
   正在更新   = False ' 改完了，开锁

